{
  "name": "norys-reels",
  "productName": "Norys Reels",
  "version": "2.5.9",
  "description": "Duplicateur vidéo Instagram — Electron + FFmpeg",
  "main": "main.js",
  "private": true,
  "author": "Norys",
  "scripts": {
    "start": "electron .",
    "icon": "node build/generate-icon.js",
    "dist": "electron-builder --win nsis portable --publish never",
    "dist:nsis": "electron-builder --win nsis --publish never",
    "dist:portable": "electron-builder --win portable --publish never",
    "dist:mac": "electron-builder --mac dmg --publish never"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "rcedit": "^5.0.2"
  },
  "build": {
    "appId": "com.norys.reels",
    "productName": "Norys Reels",
    "asar": false,
    "publish": {
      "provider": "github",
      "owner": "nowax0tv",
      "repo": "NorysReelsApp",
      "releaseType": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      "core.js",
      "index.html",
      "fonts/**/*",
      "assets/**/*",
      "vendor/**/*",
      "package.json",
      "node_modules/ffmpeg-static/**/*",
      "node_modules/ffprobe-static/index.js",
      "node_modules/ffprobe-static/package.json",
      "!node_modules/ffprobe-static/bin/**/*",
      "node_modules/tree-kill/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/builder-util-runtime/**/*",
      "node_modules/fs-extra/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/lazy-val/**/*",
      "node_modules/lodash.escaperegexp/**/*",
      "node_modules/lodash.isequal/**/*",
      "node_modules/semver/**/*",
      "node_modules/tiny-typed-emitter/**/*",
      "node_modules/debug/**/*",
      "node_modules/sax/**/*",
      "node_modules/ms/**/*",
      "node_modules/graceful-fs/**/*",
      "node_modules/jsonfile/**/*",
      "node_modules/universalify/**/*",
      "node_modules/argparse/**/*"
    ],
    "directories": {
      "output": "dist_electron",
      "buildResources": "build"
    },
    "extraResources": [
      {
        "from": "node_modules/builder-util-runtime",
        "to": "app/node_modules/builder-util-runtime"
      },
      {
        "from": "node_modules/fs-extra",
        "to": "app/node_modules/fs-extra"
      },
      {
        "from": "node_modules/semver",
        "to": "app/node_modules/semver"
      },
      {
        "from": "node_modules/jsonfile",
        "to": "app/node_modules/jsonfile"
      }
    ],
    "afterPack": "build/after-pack-icon.js",
    "win": {
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false,
      "files": [
        "node_modules/ffprobe-static/bin/win32/x64/**/*"
      ],
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Norys Reels",
      "artifactName": "Norys_Reels.exe",
      "runAfterFinish": true
    },
    "portable": {
      "artifactName": "NorysReels-Portable.exe"
    },
    "mac": {
      "icon": "assets/icon.png",
      "category": "public.app-category.video",
      "files": [
        "node_modules/ffprobe-static/bin/darwin/**/*"
      ],
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "identity": null,
      "gatekeeperAssess": false
    },
    "dmg": {
      "artifactName": "NorysReels-Mac.dmg"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "tree-kill": "^1.2.2"
  }
}
